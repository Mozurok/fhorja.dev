{
  "_comment": "Supabase MCP server. Copy into your repo .mcp.json under mcpServers, set the env, then approve the pending server in Claude Code. Backs the Fhorja db-context-supabase command. Read-only by default via --read-only; drop that flag only if a command legitimately needs writes.",
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@latest", "--read-only", "--project-ref=${SUPABASE_PROJECT_REF}"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    }
  }
}
